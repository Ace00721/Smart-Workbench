    q2 = q.replace(" ", "_")
    if q2 in FIXED_TOOL_ORDER:
        return q2
    return None

def extract_tool_from_text(text):
    text_n = normalize_name(text)

    alias_keys = sorted(SEARCH_ALIASES.keys(), key=len, reverse=True)
    for alias in alias_keys:
        if alias in text_n:
            return SEARCH_ALIASES[alias]

    collapsed = text_n.replace(" ", "_")
    for nm in FIXED_TOOL_ORDER:
        spoken = nm.replace("_", " ")
        if spoken in text_n or nm in collapsed:
            return nm

    return None

def parse_voice_command(text):
    t = normalize_name(text)
    if not t:
        return ("none", None)

    wake_words = ["forge", "forage"]
    matched_wake = None

    for w in wake_words:
        if t == w:
            return ("wake_only", None)
        if t.startswith(w + " "):
            matched_wake = w
            break

    if matched_wake is None:
        return ("none", None)

    t = t[len(matched_wake):].strip()
    if not t:
        return ("wake_only", None)

    if any(x in t for x in ["quit", "exit", "close program"]):
        return ("quit", None)

    if any(x in t for x in ["what do you see", "visible tools"]):
        return ("summary", None)

    if "status" in t:
        return ("status", None)

    if any(x in t for x in ["auto", "auto mode"]):
        return ("auto", None)

    if any(x in t for x in ["unlock", "clear lock", "stop locking"]):
        return ("unlock", None)

    if any(x in t for x in ["find", "lock", "track", "point to", "point at", "select"]):
        tool = extract_tool_from_text(t)
        if tool is not None:
            return ("lock_tool", tool)

    tool = canonicalize_tool_name(t)
    if tool is not None:
        return ("lock_tool", tool)

    return ("unknown_after_wake", t)

def voice_audio_callback(indata, frames, time_info, status):
    if status:
        print(f"[VOICE STATUS] {status}")
    voice_audio_queue.put(bytes(indata))

def voice_listener_worker():
    try:
        vosk_model = VoskModel(VOSK_MODEL_PATH)
        rec = KaldiRecognizer(vosk_model, VOICE_TARGET_RATE, VOICE_GRAMMAR)
        rec.SetWords(False)

        with sd.RawInputStream(
            samplerate=VOICE_INPUT_RATE,
            blocksize=VOICE_BLOCKSIZE,
            device=VOICE_DEVICE,
            dtype="int16",
            channels=1,
            callback=voice_audio_callback,
        ):
            print("[VOICE] Listening...")
            while True:
                data_48k = voice_audio_queue.get()
                if data_48k is None:
                    break

                data_16k = downsample_48k_to_16k(data_48k)

                if rec.AcceptWaveform(data_16k):
                    res = json.loads(rec.Result())
                    text = normalize_name(res.get("text", ""))
                    if text:
                        print(f"[VOICE RAW] {text}")
                        voice_command_queue.put(text)
                else:
                    _ = rec.PartialResult()

    except Exception as e:
        print(f"[VOICE] Failed to start: {e}")

