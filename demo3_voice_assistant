                search_text = ""
                continue

            if key in (8, 127):
                search_text = search_text[:-1]
                continue

            if 32 <= key <= 126:
                ch = chr(key)
                if ch.isalnum() or ch in (" ", "_", "-"):
                    if len(search_text) < 22:
                        search_text += ch
                continue

            continue

        if key == 9:
            selected_idx = (selected_idx + 1) % len(FIXED_TOOL_ORDER)

        elif key in (10, 13):
            nm = FIXED_TOOL_ORDER[selected_idx]
